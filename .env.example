# BluePrintAI environment variables
# Copy this to apps/web/.env.local and fill in values you need.
# The app runs in DEMO MODE (procedural plan generator) without any of these.

# ── LLMs (optional — enables real prompt-to-2D) ──────────────────────────────
# Set ANY ONE of these to enable real AI generation.
# Order tried: Gemini → Claude → OpenAI → heuristic fallback.
# - Gemini key:  https://aistudio.google.com/apikey  (free tier available)
# - Claude key:  https://console.anthropic.com/settings/keys
# - OpenAI key:  https://platform.openai.com/api-keys
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Firebase (optional — enables cross-device project sync) ──────────────────
# Without these, projects are saved to localStorage in the browser.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server-side admin SDK (for Firestore rules + writes from API routes)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ── Razorpay (optional — enables paid plans) ────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── PostHog (optional — analytics) ──────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
