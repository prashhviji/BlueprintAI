{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "functions": {
    "app/api/generate/route.ts": {
      "maxDuration": 60
    },
    "app/api/refine/route.ts": {
      "maxDuration": 60
    },
    "app/api/export/pdf/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "app/api/export/dxf/route.ts": {
      "maxDuration": 30
    },
    "app/api/export/csv/route.ts": {
      "maxDuration": 30
    },
    "app/api/health/route.ts": {
      "maxDuration": 10
    }
  }
}
